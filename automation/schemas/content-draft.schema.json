{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Web Direction Lab daily content bundle",
  "type": "object",
  "additionalProperties": true,
  "required": ["runDate", "knowledge", "news", "column", "reviewChecklist"],
  "properties": {
    "runDate": { "type": "string", "format": "date" },
    "knowledge": { "$ref": "#/$defs/knowledge" },
    "news": { "$ref": "#/$defs/news" },
    "column": { "$ref": "#/$defs/column" },
    "reviewChecklist": { "$ref": "#/$defs/reviewChecklist" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "model": { "type": "string" },
    "responseId": { "type": "string" }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "publishedAt", "isPrimary"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "publishedAt": { "type": "string", "minLength": 4 },
        "isPrimary": { "type": "boolean" }
      }
    },
    "quiz": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question", "choices", "answer", "explanation"],
      "properties": {
        "question": { "type": "string", "minLength": 1 },
        "choices": {
          "type": "array",
          "minItems": 3,
          "maxItems": 4,
          "items": { "type": "string", "minLength": 1 }
        },
        "answer": { "type": "string", "minLength": 1 },
        "explanation": { "type": "string", "minLength": 1 }
      }
    },
    "knowledge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "status", "title", "slug", "category", "summary", "level", "minutes", "hero", "body", "seo", "sources"],
      "properties": {
        "kind": { "const": "knowledge" },
        "status": { "enum": ["draft", "approved", "published"] },
        "title": { "type": "string", "minLength": 8 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "category": { "enum": ["SEO", "Web制作", "アクセス解析", "システム", "AI活用", "マーケティング", "UX", "Webディレクション"] },
        "summary": { "type": "string", "minLength": 40 },
        "level": { "enum": ["初級", "中級", "上級"] },
        "minutes": { "type": "integer", "minimum": 5, "maximum": 30 },
        "hero": {
          "type": "object",
          "required": ["label", "headline", "items"],
          "properties": {
            "label": { "type": "string" },
            "headline": { "type": "string" },
            "items": { "type": "array", "minItems": 3, "maxItems": 4, "items": { "type": "string" } }
          }
        },
        "body": {
          "type": "object",
          "required": ["conclusion", "highlights", "glossary", "definition", "importance", "practice", "mistakes", "example", "quiz"],
          "properties": {
            "conclusion": { "type": "string" },
            "highlights": { "type": "array", "minItems": 3, "maxItems": 5, "items": { "type": "string" } },
            "glossary": {
              "type": "array",
              "minItems": 5,
              "maxItems": 10,
              "items": {
                "type": "object",
                "required": ["term", "description"],
                "properties": {
                  "term": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            },
            "definition": { "type": "string" },
            "importance": { "type": "string" },
            "practice": { "type": "string" },
            "mistakes": { "type": "string" },
            "example": { "type": "string" },
            "quiz": { "$ref": "#/$defs/quiz" }
          }
        },
        "seo": {
          "type": "object",
          "required": ["metaTitle", "metaDescription", "keywords"],
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "keywords": { "type": "array", "minItems": 3, "maxItems": 8, "items": { "type": "string" } }
          }
        },
        "sources": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "$ref": "#/$defs/source" } }
      }
    },
    "news": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "status", "title", "slug", "category", "serviceName", "summary", "quickSummary", "keywords", "whatHappened", "impact", "action", "urgency", "audienceImpact", "selectionReason", "sources"],
      "properties": {
        "kind": { "const": "news" },
        "status": { "enum": ["draft", "approved", "published"] },
        "title": { "type": "string", "minLength": 8 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "category": { "enum": ["AI", "検索・SEO", "アクセス解析・広告", "ブラウザ・Web標準", "Web制作・CMS", "クラウド・インフラ", "セキュリティ・プライバシー", "Webサービス"] },
        "serviceName": { "type": "string" },
        "summary": { "type": "string", "minLength": 40 },
        "quickSummary": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "string" } },
        "keywords": { "type": "array", "minItems": 3, "maxItems": 8, "items": { "type": "string" } },
        "whatHappened": { "type": "string" },
        "impact": { "type": "string" },
        "action": { "type": "string" },
        "urgency": { "type": "integer", "minimum": 1, "maximum": 5 },
        "audienceImpact": { "type": "integer", "minimum": 1, "maximum": 5 },
        "selectionReason": { "type": "string" },
        "sources": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "$ref": "#/$defs/source" } }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "status", "title", "slug", "category", "summary", "videoHook", "lead", "sections", "seo"],
      "properties": {
        "kind": { "const": "column" },
        "status": { "enum": ["draft", "approved", "published"] },
        "title": { "type": "string", "minLength": 8 },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "category": { "enum": ["Webの仕事術", "AI活用", "サイト改善", "キャリア・学習"] },
        "summary": { "type": "string", "minLength": 40 },
        "videoHook": { "type": "string", "minLength": 8 },
        "lead": { "type": "string", "minLength": 80 },
        "sections": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "body"],
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string", "minLength": 200 }
            }
          }
        },
        "seo": {
          "type": "object",
          "required": ["metaTitle", "metaDescription", "keywords"],
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "keywords": { "type": "array", "minItems": 3, "maxItems": 8, "items": { "type": "string" } }
          }
        }
      }
    },
    "reviewChecklist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["factChecked", "primarySourcesChecked", "duplicateChecked", "seoChecked", "approvedBy"],
      "properties": {
        "factChecked": { "type": "boolean" },
        "primarySourcesChecked": { "type": "boolean" },
        "duplicateChecked": { "type": "boolean" },
        "seoChecked": { "type": "boolean" },
        "approvedBy": { "type": ["string", "null"] }
      }
    }
  }
}
